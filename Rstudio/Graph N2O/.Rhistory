)
scale_factor <- max(plot_data$mean, na.rm = TRUE) /
max(rain_all$Rain, na.rm = TRUE)
y_top <- max(plot_data$upper, na.rm = TRUE) * 1.2
cols <- c(
"CTR" = "black",
"SA"  = "#7CAE00",
"RAW" = "#00BFC4",
"AA"  = "#C77CFF"
)
final_plot <- ggplot(
plot_data,
aes(
x = Date,
y = mean,
colour = Treatment,
fill = Treatment,
group = Treatment
)
) +
## Rain
geom_rect(
data = rain_all,
aes(
xmin = Date - 0.4,
xmax = Date + 0.4,
ymin = y_top - Rain * scale_factor,
ymax = y_top
),
inherit.aes = FALSE,
fill = "#4FA3D9",
alpha = 0.45
) +
## SD ribbon (non per CTR)
geom_ribbon(
data = subset(plot_data, Treatment != "CTR"),
aes(
ymin = lower,
ymax = upper
),
alpha = 0.20,
colour = NA
) +
geom_line(linewidth = 1.2) +
geom_point(size = 1.6) +
facet_wrap(
~Animal,
nrow = 1
) +
scale_colour_manual(
values = cols,
labels = c(
CTR = "CTR",
SA  = "SA",
RAW = "RAW",
AA  = "AA"
),
name = NULL
) +
scale_fill_manual(
values = cols,
guide = "none"
) +
scale_y_continuous(
name = expression(
N[2]*O*"-N (mg "*m^{-2}*" h"^{-1}*")"
),
sec.axis = sec_axis(
~ (y_top - .)/scale_factor,
name = "Rain (mm)"
),
expand = expansion(mult = c(0.02,0.15))
) +
labs(
x = "Days after application"
) +
theme_minimal(base_size = 15) +
theme(
strip.text = element_text(
size = 18,
face = "bold"
),
axis.title = element_text(size = 18),
axis.text = element_text(size = 15),
axis.text.x = element_text(
angle = 45,
hjust = 1
),
legend.position = "top",
legend.direction = "horizontal",
legend.text = element_text(size = 15),
legend.background = element_rect(
fill = "white",
colour = "grey80"
),
panel.grid.minor = element_blank()
) +
guides(
colour = guide_legend(
override.aes = list(
shape = 16,
size = 4,
linewidth = 1
),
nrow = 1
),
fill = "none"
)
final_plot
rm(list = ls())
