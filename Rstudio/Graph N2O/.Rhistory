Type,
!!treatments[1] := "SA",
!!treatments[2] := "RAW",
!!treatments[3] := "AA"
),
Animal = animal
)
ctr_plot <- CTR_by_date %>%
mutate(
mean = CTR_Date * 1000 * conv_factor,
lower = NA,
upper = NA,
Treatment = "CTR",
Animal = animal
) %>%
select(
Date,
mean,
lower,
upper,
Treatment,
Animal
)
bind_rows(summary_df, ctr_plot)
}
