library(tidyverse)
library(readxl)
library(scales)
library(grid)
df <- read_excel("Flux.xlsx") %>%
mutate(Date = as.Date(Date))
conv_factor <- 28 / 44
prepare_data <- function(data,
treatments,
exclude_dates,
animal){
df_filt <- data %>%
filter(
Compound == "N2O",
!Date %in% as.Date(exclude_dates),
Type %in% c(treatments, "CTR")
)
CTR_by_date <- df_filt %>%
filter(Type == "CTR") %>%
group_by(Date) %>%
summarise(
CTR_Date = mean(flux.final, na.rm = TRUE),
.groups = "drop"
)
df_norm <- df_filt %>%
left_join(CTR_by_date, by = "Date") %>%
mutate(
flux_minus_CTR = flux.final - CTR_Date
)
summary_df <- df_norm %>%
filter(Type != "CTR") %>%
group_by(Date, Type) %>%
summarise(
mean = mean(flux_minus_CTR, na.rm = TRUE),
sd = sd(flux_minus_CTR, na.rm = TRUE),
.groups = "drop"
) %>%
mutate(
sd = replace_na(sd,0),
mean = mean * 1000 * conv_factor,
sd = sd * 1000 * conv_factor,
lower = mean - sd,
upper = mean + sd,
Treatment = recode(
Type,
!!treatments[1] := "SA",
!!treatments[2] := "RAW",
!!treatments[3] := "AA"
),
Animal = animal
)
ctr_plot <- CTR_by_date %>%
mutate(
mean = CTR_Date * 1000 * conv_factor,
lower = NA,
upper = NA,
Treatment = "CTR",
Animal = animal
) %>%
select(
Date,
mean,
lower,
upper,
Treatment,
Animal
)
bind_rows(summary_df, ctr_plot)
}
