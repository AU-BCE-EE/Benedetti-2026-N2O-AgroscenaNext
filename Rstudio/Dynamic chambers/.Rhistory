library(tidyverse)
library(readxl)
library(ggplot2)
library(patchwork)
setwd("/Users/lorenzobenedetti/Desktop/Università/DiANA/Dottorato/Danimarca/AU/Agroscena Next/DFC_SC_Lorenzo_Pablo/Static chambers")
df <- read_excel("Flux.xlsx") %>%
mutate(Date = as.Date(Date))
conv_factor <- 28/44
make_plot <- function(df, treatments, excluded_dates, rain_df, title_text, colors){
df_filt <- df %>%
filter(
Compound == "N2O",
!Date %in% excluded_dates,
Type %in% c(treatments, "CTR")
)
ctr <- df_filt %>%
filter(Type == "CTR") %>%
group_by(Date) %>%
summarise(CTR = mean(flux.final, na.rm = TRUE), .groups = "drop")
df_main <- df_filt %>%
left_join(ctr, by = "Date") %>%
mutate(flux_adj = flux.final - CTR)
summary <- df_main %>%
filter(Type != "CTR") %>%
group_by(Date, Type) %>%
summarise(
mean = mean(flux_adj, na.rm = TRUE),
sd   = sd(flux_adj, na.rm = TRUE),
.groups = "drop"
) %>%
mutate(
sd = ifelse(is.na(sd), 0, sd),
mean  = mean * 1000 * conv_factor,
sd    = sd * 1000 * conv_factor,
lower = mean - sd,
upper = mean + sd
)
ctr_plot <- ctr %>%
transmute(
Date,
mean = CTR * 1000 * conv_factor,
lower = NA,
upper = NA,
Type = "CTR"
)
plot_data <- bind_rows(summary, ctr_plot)
plot_data$Type <- factor(plot_data$Type, levels = c("CTR", treatments))
# scale rain (LOCAL per plot)
scale_factor <- max(plot_data$mean, na.rm = TRUE) /
max(rain_df$Rain, na.rm = TRUE)
y_top <- max(plot_data$upper, na.rm = TRUE) * 1.2
ggplot(plot_data, aes(Date, mean, colour = Type, fill = Type)) +
geom_rect(
data = rain_df,
aes(
xmin = Date - 0.4,
xmax = Date + 0.4,
ymin = y_top - Rain * scale_factor,
ymax = y_top
),
inherit.aes = FALSE,
fill = "#4FA3D9",
alpha = 0.4
) +
geom_ribbon(
data = subset(plot_data, Type != "CTR"),
aes(ymin = lower, ymax = upper),
alpha = 0.2,
colour = NA
) +
geom_line(linewidth = 1.1) +
geom_point(size = 1.4) +
scale_color_manual(values = colors, name = NULL) +
scale_fill_manual(values = colors, guide = "none") +
scale_y_continuous(
name = expression(N[2]*O*" -N (mg m"^{-2}*" h"^{-1}*")"),
sec.axis = sec_axis(~ (y_top - .) / scale_factor,
name = "Rain (mm)")
) +
labs(title = title_text, x = "Days after application") +
theme_minimal(base_size = 14) +
theme(
axis.text.x = element_text(angle = 45, hjust = 1),
legend.position = "top",
plot.title = element_text(face = "bold", hjust = 0.5)
)
}
