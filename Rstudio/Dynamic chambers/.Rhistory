library(readxl)
library(dplyr)
library(ggplot2)
library(car)
library(emmeans)
library(performance)
library(FSA)
# Import dati
data <- read_excel("Cattle Final NH3.xlsx")
# Rinomina variabile (se necessario)
data <- data %>%
rename(NH3_TN = `N-NH3 perc TN`)
# Assicurati che TREATMENT sia fattore
data$TREATMENT <- as.factor(data$TREATMENT)
# Statistiche descrittive
desc <- data %>%
group_by(TREATMENT) %>%
summarise(
mean = mean(NH3_TN, na.rm = TRUE),
sd = sd(NH3_TN, na.rm = TRUE),
se = sd / sqrt(n()),
n = n()
)
print(desc)
# Modello lineare
model <- lm(NH3_TN ~ TREATMENT, data = data)
summary(model)
# ANOVA
anova(model)
# Test non parametrico
kruskal.test(NH3_TN ~ TREATMENT, data = data)
# Dunn test (post-hoc non parametrico)
dunnTest(NH3_TN ~ TREATMENT, data = data, method = "bonferroni")
# Post-hoc parametrico (Tukey)
posthoc <- emmeans(model, pairwise ~ TREATMENT, adjust = "tukey")
posthoc$emmeans
posthoc$contrasts
# Assunzioni modello
shapiro.test(residuals(model))
leveneTest(NH3_TN ~ TREATMENT, data = data)
check_model(model)
# Diagnostica grafica
par(mfrow = c(2,2))
plot(model)
# Boxplot
ggplot(data, aes(x = TREATMENT, y = NH3_TN, fill = TREATMENT)) +
geom_boxplot() +
theme_bw() +
labs(
x = "Treatment",
y = "N-NH3 (% of TN)",
title = "N-NH3 percentage of total N"
)
rm(list = ls())
