# Librerie
library(ggplot2)
library(tidyr)
library(dplyr)
data <- data.frame(
Giorno = c(1, 3, 7, 14, 28, 60, 90),
CTR = c(250.82, 224.98, 213.12, 201.39, 209.57, 87.3028, 88.0771),
ME  = c(260.17, 250.06, 232.93, 177.93, 288.79, 81.9166, 86.5012),
SOP = c(133.72, 92.1048, 141.06, 161.62, 249.14, 85.3657, 86.1346)
)
SEM <- 8.9883   # SEM costante
data_long <- data %>%
pivot_longer(cols = c(CTR, ME, SOP),
names_to = "Trattamento",
values_to = "Valore")
data_long$SEM <- SEM
lettere <- data.frame(
Giorno = rep(c(1, 3, 7, 14, 28, 60, 90), each = 3),
Trattamento = rep(c("CTR", "ME", "SOP"), times = 7),
Lettera = c(
"a","a","b",
"a","a","b",
"a","a","a",
"a","b","b",
"b","a","a",
"a","a","a",
"a","a","a"
)
)
data_long <- left_join(data_long, lettere,
by = c("Giorno", "Trattamento"))
grafico <- ggplot(data_long,
aes(x = Giorno,
y = Valore,
color = Trattamento,
group = Trattamento)) +
geom_line(linewidth = 1) +
geom_point(size = 3) +
geom_errorbar(aes(ymin = Valore - SEM,
ymax = Valore + SEM),
width = 2,
linewidth = 0.7) +
geom_text(aes(label = Lettera),
vjust = -1.5,
size = 5,
show.legend = FALSE) +
scale_color_manual(values = c("black", "grey40", "grey70")) +
theme_classic(base_size = 14) +
labs(x = "Giorni",
y = "Valore",
color = "Trattamento")
print(grafico)
