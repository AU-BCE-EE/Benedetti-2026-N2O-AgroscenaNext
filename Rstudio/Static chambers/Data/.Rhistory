library(readxl)
library(data.table)
library(ggplot2)
library(car)
Data<-(read_excel("chamber_data.xlsx"))
names(Data)
Data <- Data[Data$ID %in% c("CTR", "CSAA", "CSH2SO4", "CSRAW"), ]
#Data <- Data[Data$ID %in% c("CTR", "PSAA", "PSH2SO4", "PSRAW"), ]
Data$Difftime<-difftime(Data$`End_time`,Data$`Start_time`,units = "secs")
Data$emissionsestimate<-(Data$`End N2O (ppm)`-Data$`Start N2O (ppm)`)/as.numeric (Data$Difftime)
Data$N2Og<-(44*1e-3)/(0.082*293)
Data$emissionsestimate<-(Data$emissionsestimate*Data$N2Og)
Data<-data.table(Data)
print(Data)
Data$Date <- as.Date(Data$Date, format = "%y-%m-%d")
subset_data <- Data[Date == as.Date("2025-10-30")]
print(subset_data)
ggplot(Data, aes(x = Date, y = emissionsestimate, color = as.factor(ID))) +
geom_point(size = 2) +
geom_line() +
scale_x_date(date_breaks = "1 day", date_labels = "%Y-%m-%d") +  # forza un tick per ogni giorno
labs(
title = "Emissioni N2O",
x = "Data",
y = "Emissioni (g/m³/s)",
color = "Chamber"
) +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
# Calcolate mean and SE
Data_summary <- Data[, .(
mean_emissions = mean(emissionsestimate, na.rm = TRUE),
se = sd(emissionsestimate, na.rm = TRUE) / sqrt(.N)
), by = .(ID, Date)]
setorder(Data_summary, ID, Date)
Data_summary <- Data_summary[!is.na(mean_emissions) & !is.na(Date)]
ggplot(Data_summary, aes(x = Date, y = mean_emissions, color = ID)) +
geom_line(size = 1.2) +
geom_point(size = 2) +
geom_errorbar(aes(ymin = mean_emissions - se, ymax = mean_emissions + se), width = 0.2) +
labs(
#title = "N2O Emissions (mean ± SE)",
x = "Time",
y = "Emissions estimate (g N2O/m²/s)",
color = "Treatment"
) +
theme_minimal() +
theme(
axis.text.x = element_text(angle = 45, hjust = 1),
text = element_text(size = 12)
)
