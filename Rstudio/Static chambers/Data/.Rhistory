grViz("
digraph dairy_N_flow {
# Layout orizzontale
graph [rankdir = LR, fontsize = 12, fontname = Helvetica]
# Stile dei nodi
node [shape = rect, style = rounded, fontname = Helvetica, fontsize = 12,
color = gray40, fontcolor = black, penwidth = 1.2, width = 2.2]
# Definizione nodi con colori tenui
diet     [label = 'Nitrogen input\\n(Diet)', fillcolor = '#E3F2FD', style = filled, color = '#90CAF9']
cow      [label = 'Cow', fillcolor = '#FFF3E0', style = filled, color = '#FFB74D']
milk     [label = 'Milk production', fillcolor = '#E8F5E9', style = filled, color = '#81C784']
barn     [label = 'Barn\\nNH3 from manure', fillcolor = '#F3E5F5', style = filled, color = '#BA68C8']
storage  [label = 'Storage\\n(slurry tank)\\nNH3 from manure', fillcolor = '#FBE9E7', style = filled, color = '#FF8A65']
landapp  [label = 'Land application\\nNH3 from manure', fillcolor = '#FFFDE7', style = filled, color = '#FFF176']
# Stile delle frecce
edge [arrowhead = vee, color = gray40, penwidth = 1.2]
# Collegamenti
diet -> cow
cow -> milk [style = dashed, color = '#81C784'] # linea tratteggiata per la produzione di latte
cow -> barn
barn -> storage
storage -> landapp
}
")
archaeol <- c(
0.00, 0.00, 0.00, 1.63, 2.29, 3.05, 3.32, 3.86, 4.24, 7.86,
11.23, 12.53, 13.13, 13.23, 13.23, 13.38, 13.93, 13.99, 14.46, 14.90,
20.33, 22.12, 22.28, 25.81, 27.30, 30.63
)
