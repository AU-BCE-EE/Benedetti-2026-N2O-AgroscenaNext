storage -> landapp
}
")
fonti <- c("Livestock",
"Slurry spreading",
"Nitrogen fertilizers",
"Grazing",
"Other organic fertilizers",
"Sewage sludge",
"Burning agricultural residues",
"Crop residues")
percentuali <- c(57.3, 20.6, 13.9, 3.1, 3.8, 0.3, 0.1, 1.0)
barplot(percentuali,
names.arg = fonti,
col = "skyblue",
xlab = "Source",
ylab = "Percentage (%)",
las = 1,                # Rotazione etichette sull’asse X
cex.names = 0.5)
#Con etichette a 45°
fonti <- c("Livestock",
"Slurry spreading",
"Nitrogen fertilizers",
"Grazing",
"Other organic fertilizers",
"Sewage sludge",
"Burning agricultural residues",
"Crop residues")
percentuali <- c(57.3, 20.6, 13.9, 3.1, 3.8, 0.3, 0.1, 1.0)
# Imposta i margini del grafico per fare spazio alle etichette ruotate
# c(bottom, left, top, right) - aumentiamo il margine inferiore
par(mar = c(10, 4, 4, 2) + 0.1)
# Crea il barplot senza le etichette dell'asse X (xaxt = "n")
bp <- barplot(percentuali,
# names.arg = fonti, # Non usiamo names.arg qui, le aggiungiamo dopo
col = "skyblue",
main = "Sources of ammonia emissions from agriculture in Italy (ISPRA 2024)",
xlab = "", # Lascia l'etichetta X vuota, o mettila in un secondo momento se vuoi
ylab = "Percentage (%)",
ylim = c(0, max(percentuali) * 1.1), # Aggiungi un po' di spazio sopra
xaxt = "n", # Sopprimi le etichette predefinite dell'asse X
las = 1) # las = 1 per le etichette dell'asse Y orizzontali
# Aggiungi le etichette dell'asse X ruotate
text(x = bp, # Le posizioni x delle barre restituite da barplot()
y = par("usr")[3] - 1.5, # Posizione verticale: par("usr")[3] è il limite inferiore del grafico, -0.5 lo sposta leggermente sotto
labels = fonti, # Le tue etichette
xpd = TRUE, # Permette al testo di uscire dall'area del plot se necessario
srt = 45, # Angolo di rotazione (45 gradi)
adj = 1, # Allineamento: 1 per allineare a destra del punto x (funziona bene con 45°)
cex = 0.9) # Dimensione del testo (puoi aggiustarla)
# Aggiungi l'etichetta per l'asse X
mtext("Source", side = 1, line = 8) # side=1 per l'asse x, line=8 per la posizione
# Ripristina i margini predefiniti dopo aver generato il grafico
# per non influenzare i grafici successivi
par(mar = c(5, 4, 4, 2) + 0.1)
