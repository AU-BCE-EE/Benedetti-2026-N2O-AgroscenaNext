subset_data <- Data[Date == as.Date("2025-10-30")]
print(subset_data)
ggplot(Data, aes(x = Date, y = emissionsestimate, color = as.factor(ID))) +
geom_point(size = 2) +
geom_line() +
scale_x_date(date_breaks = "1 day", date_labels = "%Y-%m-%d") +  # forza un tick per ogni giorno
labs(
title = "Emissioni N2O",
x = "Data",
y = "Emissioni (g/m³/s)",
color = "Chamber"
) +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
# Calcolate mean and SE
Data_summary <- Data[, .(
mean_emissions = mean(emissionsestimate, na.rm = TRUE),
se = sd(emissionsestimate, na.rm = TRUE) / sqrt(.N)
), by = .(ID, Date)]
setorder(Data_summary, ID, Date)
Data_summary <- Data_summary[!is.na(mean_emissions) & !is.na(Date)]
ggplot(Data_summary, aes(x = Date, y = mean_emissions, color = ID)) +
geom_line(size = 1.2) +
geom_point(size = 2) +
geom_errorbar(aes(ymin = mean_emissions - se, ymax = mean_emissions + se), width = 0.2) +
labs(
#title = "N2O Emissions (mean ± SE)",
x = "Time",
y = "Emissions estimate (g N2O/m²/s)",
color = "Treatment"
) +
theme_minimal() +
theme(
axis.text.x = element_text(angle = 45, hjust = 1),
text = element_text(size = 12)
)
