388.08, NA, NA, 515.69, 427.59, 465.27
)
# Creazione dataframe
df <- data.frame(Archaeol = archaeol, CH4 = ch4)
# Rimozione righe con valori mancanti
df_clean <- na.omit(df)
# Regressione lineare
model <- lm(CH4 ~ Archaeol, data = df_clean)
summary(model)
# Grafico
plot(df_clean$Archaeol, df_clean$CH4,
main = "Regressione lineare Archaeol ~ CH4",
xlab = "Archaeol",
ylab = "CH4",
pch = 19,
col = "blue")
abline(model, col = "red", lwd = 2)
# Mostra coefficiente di correlazione sul grafico
cor_value <- cor(df_clean$Archaeol, df_clean$CH4)
legend("topleft",
legend = paste("Correlazione =", round(cor_value, 3)),
bty = "n")
